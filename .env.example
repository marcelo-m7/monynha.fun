# Supabase (Frontend/Public)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Supabase (Backend/Service Role - for Edge Functions)
# NOTE: Service role key should NEVER be exposed to client
# Store in Supabase secrets management
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API Integration (Phase 2)
# Used for video enrichment with AI (GPT-4o-mini recommended)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Feature Flags
VITE_ENABLE_RECOMMENDATIONS=true
VITE_ENABLE_RATINGS=true
VITE_ENABLE_SOCIAL_FEATURES=true
VITE_ENABLE_PWA=true
